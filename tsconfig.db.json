{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "lib": ["ES2022"],
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": ".",
        "outDir": "build",
        "verbatimModuleSyntax": false
    },
    "include": [
        "config/database.ts",
        "database/**/*.ts",
        "src/models/**/*.ts"
    ]
}
